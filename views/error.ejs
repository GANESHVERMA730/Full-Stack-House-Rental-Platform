<% layout("/layouts/boilerplate") %>

<div class="error-page">
  <div class="alert alert-danger error-alert" role="alert">
    <h4 class="alert-heading d-flex align-items-center gap-2">
      <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
      Something went wrong
    </h4>
    <hr>
    <p class="mb-0"><%= message %></p>
  </div>
  <a href="/listings" class="btn btn-dark mt-3">
    <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>Back to listings
  </a>
</div>
