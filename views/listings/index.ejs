<% layout("/layouts/boilerplate") %>

<div id="filters-wrapper">
  <div id="filters">
    <a href="/listings" class="filter <%= !activeCategory ? 'filter-active' : '' %>">
      <i class="fa-solid fa-border-all" aria-hidden="true"></i>
      <p>All</p>
    </a>
    <a href="/listings?category=trending" class="filter <%= activeCategory === 'trending' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-fire" aria-hidden="true"></i>
      <p>Trending</p>
    </a>
    <a href="/listings?category=rooms" class="filter <%= activeCategory === 'rooms' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-bed" aria-hidden="true"></i>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=cities" class="filter <%= activeCategory === 'cities' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-mountain-city" aria-hidden="true"></i>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=castles" class="filter <%= activeCategory === 'castles' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-dungeon" aria-hidden="true"></i>
      <p>Castles</p>
    </a>
    <a href="/listings?category=mountains" class="filter <%= activeCategory === 'mountains' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-mountain" aria-hidden="true"></i>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=arctic" class="filter <%= activeCategory === 'arctic' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-snowflake" aria-hidden="true"></i>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=camping" class="filter <%= activeCategory === 'camping' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-campground" aria-hidden="true"></i>
      <p>Camping</p>
    </a>
    <a href="/listings?category=farmhouse" class="filter <%= activeCategory === 'farmhouse' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-cow" aria-hidden="true"></i>
      <p>Farm House</p>
    </a>
    <a href="/listings?category=villa" class="filter <%= activeCategory === 'villa' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-synagogue" aria-hidden="true"></i>
      <p>Villa</p>
    </a>
    <a href="/listings?category=boats" class="filter <%= activeCategory === 'boats' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-ship" aria-hidden="true"></i>
      <p>Boats</p>
    </a>
  </div>

  <div class="tax-toggle">
    <div class="form-check form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Show total with taxes</label>
    </div>
  </div>
</div>

<% if (searchQuery) { %>
  <p class="search-results-meta">
    <% if (allListings.length > 0) { %>
      Showing <strong><%= allListings.length %></strong> result<%= allListings.length !== 1 ? 's' : '' %> for "<strong><%= searchQuery %></strong>"
      &mdash; <a href="/listings">Clear</a>
    <% } else { %>
      No results for "<strong><%= searchQuery %></strong>". <a href="/listings">Browse all listings</a>
    <% } %>
  </p>
<% } %>

<% if (allListings.length === 0) { %>
  <div class="empty-state">
    <i class="fa-solid fa-compass" aria-hidden="true"></i>
    <% if (searchQuery) { %>
      <p>No results for your search.</p>
      <a href="/listings" class="btn btn-outline-brand btn-sm">Browse all listings</a>
    <% } else if (activeCategory) { %>
      <p>No listings in this category yet.</p>
      <a href="/listings" class="btn btn-outline-brand btn-sm">Browse all</a>
    <% } else { %>
      <p>No listings available yet. Be the first to host!</p>
      <a href="/listings/new" class="btn add-btn btn-sm">Create a listing</a>
    <% } %>
  </div>
<% } else { %>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 listings-grid">
    <% for (let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <article class="card listing-card">
            <div class="listing-card-img-wrap">
              <img src="<%= listing.image.url %>" class="listing-card-img" alt="<%= listing.title %>" loading="lazy" />
              <div class="card-img-overlay"></div>
            </div>
            <div class="card-body">
              <p class="listing-card-title"><%= listing.title %></p>
              <p class="listing-card-location"><%= listing.location %>, <%= listing.country %></p>
              <p class="listing-card-price">
                &#x20B9;&nbsp;<strong><%= listing.price.toLocaleString("en-IN") %></strong> / night
                <span class="tax-info">&nbsp;+18% GST</span>
              </p>
            </div>
          </article>
        </a>
      </div>
    <% } %>
  </div>
<% } %>
