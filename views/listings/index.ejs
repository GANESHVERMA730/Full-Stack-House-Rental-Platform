<% layout("/layouts/boilerplate") %>

  <body>
    
    <style>
      /* Wrapper */
      #filters-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 1rem 1rem;
      }

      /* Scrollable filters */
      #filters {
        display: flex;
        gap: 1.2rem;
        overflow-x: auto;
        white-space: nowrap;
        flex: 1;
        scroll-behavior: smooth;
      }

      #filters::-webkit-scrollbar {
        display: none;
      }

      /* Filter item */
      .filter {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-width: 80px;
        flex-shrink: 0;
        opacity: 0.7;
        font-size: 0.9rem;
        transition: all 0.2s ease;
      }

      .filter i {
        font-size: 1rem;
        margin-bottom: 0.3rem;
      }

      .filter:hover {
        opacity: 1;
        transform: scale(1.05);
        cursor: pointer;
      }

      /* Tax toggle */
      .tax-toggle {
        border: 1px solid #ddd;
        border-radius: 999px;
        padding: 0.4rem 1rem;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        background: #fff;
        transition: all 0.2s ease;
      }

      .tax-toggle:hover {
        border-color: #000;
      }

      /* Tax info */
      .tax-info {
        display: none;
        font-size: 0.9rem;
        color: #555;
      }

      /* 🔥 MOBILE (<768px) */
      @media (max-width: 768px) {

        #filters-wrapper {
          flex-direction: column;
          align-items: stretch;
          gap: 0.8rem;
        }

        #filters {
          width: 100%;
          gap: 1rem;
        }

        .filter {
          min-width: 70px;
          font-size: 0.8rem;
        }

        .filter i {
          font-size: 0.85rem;
        }

        .tax-toggle {
          width: 100%;
          justify-content: center;
          font-size: 0.85rem;
          padding: 0.6rem;
        }
      }
    </style>

    <div id="filters-wrapper">
      <div id="filters">
        <div class="filter">
          <div><i class="fa-solid fa-fire"></i></div>
          <p>Trending</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-bed"></i></div>
          <p>Rooms</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-mountain-city"></i></div>
          <p>Iconic Cities</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-dungeon"></i></div>
          <p>Castles</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-mountain"></i></div>
          <p>Mountains</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-snowflake"></i></div>
          <p>Arctic</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-campground"></i></div>
          <p>camping</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-cow"></i></div>
          <p>Farm House</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-synagogue"></i></div>
          <p>Villa</p>
        </div>
        <div class="filter">
          <div><i class="fa-solid fa-arrow-up-from-water-pump"></i></div>
          <p>Boats</p>
        </div>

        <div class="tax-toggle">
          <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
          </div>
        </div>
      </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
      <% if(locals.searchQuery) { %>
        <div class="col-12 mb-2">
          <p class="text-muted">
            <% if(allListings.length > 0) { %>
              Showing <%= allListings.length %> result<%= allListings.length !== 1 ? 's' : '' %> for "<b><%= searchQuery %></b>"
            <% } else { %>
              No results found for "<b><%= searchQuery %></b>". <a href="/listings">Clear search</a>
            <% } %>
          </p>
        </div>
      <% } %>
      <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card col listing-card">
            <img src="<%= listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem" />
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b>
                  <%= listing.title %>
                </b> <br>
                &#x20B9; <%= listing.price.toLocaleString("en-IN") %> / night
                  <i class="tax-info"> &nbsp; &nbsp; +18% GST </i>
              </p>
            </div>
          </div>
        </a>
        <% } %>
    </div>
  </body>

  <script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (info of taxInfo) {
        if (info.style.display != "inline") {
          info.style.display = "inline";
        } else {
          info.style.display = "none";
        }

      }
    });
  </script>