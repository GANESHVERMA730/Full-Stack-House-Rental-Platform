<% layout("/layouts/boilerplate") %>

<!-- Category filters -->
<div id="filters-wrapper">
  <div id="filters">

    <a href="/listings" class="filter <%= !locals.activeCategory ? 'filter-active' : '' %>">
      <i class="fa-solid fa-border-all"></i>
      <p>All</p>
    </a>
    <a href="/listings?category=trending" class="filter <%= locals.activeCategory === 'trending' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </a>
    <a href="/listings?category=rooms" class="filter <%= locals.activeCategory === 'rooms' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=cities" class="filter <%= locals.activeCategory === 'cities' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=castles" class="filter <%= locals.activeCategory === 'castles' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-dungeon"></i>
      <p>Castles</p>
    </a>
    <a href="/listings?category=mountains" class="filter <%= locals.activeCategory === 'mountains' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=arctic" class="filter <%= locals.activeCategory === 'arctic' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-snowflake"></i>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=camping" class="filter <%= locals.activeCategory === 'camping' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </a>
    <a href="/listings?category=farmhouse" class="filter <%= locals.activeCategory === 'farmhouse' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-cow"></i>
      <p>Farm House</p>
    </a>
    <a href="/listings?category=villa" class="filter <%= locals.activeCategory === 'villa' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-synagogue"></i>
      <p>Villa</p>
    </a>
    <a href="/listings?category=boats" class="filter <%= locals.activeCategory === 'boats' ? 'filter-active' : '' %>">
      <i class="fa-solid fa-arrow-up-from-water-pump"></i>
      <p>Boats</p>
    </a>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Show total with taxes</label>
      </div>
    </div>

  </div>
</div>

<!-- Search result heading -->
<% if(locals.searchQuery) { %>
  <div class="mt-2 mb-1">
    <% if(allListings.length > 0) { %>
      <p class="text-muted">
        Showing <strong><%= allListings.length %></strong> result<%= allListings.length !== 1 ? 's' : '' %> for "<strong><%= searchQuery %></strong>"
        &mdash; <a href="/listings">Clear</a>
      </p>
    <% } else { %>
      <p class="text-muted">
        No results found for "<strong><%= searchQuery %></strong>". <a href="/listings">Browse all listings</a>
      </p>
    <% } %>
  </div>
<% } %>

<% if(locals.activeCategory && allListings.length === 0) { %>
  <div class="mt-3">
    <p class="text-muted text-center">No listings in this category yet. <a href="/listings">Browse all</a></p>
  </div>
<% } %>

<!-- Listings grid -->
<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 mt-2 g-3">
  <% for(let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 18rem;" />
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <strong><%= listing.title %></strong><br>
              <span class="text-muted small"><%= listing.location %>, <%= listing.country %></span><br>
              &#x20B9;&nbsp;<strong><%= listing.price.toLocaleString("en-IN") %></strong> / night
              <i class="tax-info text-muted">&nbsp;+18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  const taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("change", () => {
    const taxInfoItems = document.querySelectorAll(".tax-info");
    taxInfoItems.forEach(el => {
      el.style.display = taxSwitch.checked ? "inline" : "none";
    });
  });
</script>
