<% layout("/layouts/boilerplate") %>

<div class="show-header">
  <h1 class="show-title"><%= listing.title %></h1>
  <p class="show-subtitle">
  <i class="fa-solid fa-location-dot text-brand me-1" aria-hidden="true"></i>
    <%= listing.location %>, <%= listing.country %>
  </p>
</div>

<div class="row g-4">
  <div class="col-12 col-lg-8">
    <div class="card show-card">
      <img src="<%= listing.image.url %>" class="show-img" alt="<%= listing.title %>">
      <div class="card-body show-card-body">
        <p class="text-muted small mb-2">
          Hosted by <strong><%= listing.owner.username %></strong>
        </p>
        <p class="show-price">
          <strong>&#x20B9; <%= listing.price.toLocaleString("en-IN") %></strong> / night
        </p>
        <p class="show-description"><%= listing.description %></p>
      </div>
    </div>

    <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
      <div class="show-actions">
        <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">
          <i class="fa-solid fa-pen me-1" aria-hidden="true"></i>Edit
        </a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
          <button class="btn btn-outline-danger">
            <i class="fa-solid fa-trash me-1" aria-hidden="true"></i>Delete
          </button>
        </form>
      </div>
    <% } %>

    <section class="mt-4">
      <h2 class="show-section-title">Where you'll be</h2>
      <% if (listing.geometry && listing.geometry.coordinates) { %>
        <div id="map" class="listing-map"
          data-coords="<%- JSON.stringify(listing.geometry.coordinates) %>"
          data-title="<%= listing.title %>"
          data-location="<%= listing.location %>">
        </div>
      <% } else { %>
        <p class="text-muted">Map not available for this listing.</p>
      <% } %>
    </section>
  </div>

  <div class="col-12 col-lg-4">
    <div class="review-section">
      <% if (currUser) { %>
        <h2 class="show-section-title h5">Leave a review</h2>
        <div class="review-form-box">
          <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
              <label class="form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
            <div class="mb-3">
              <label for="comment" class="form-label">Comments</label>
              <textarea name="review[comment]" id="comment" rows="4" class="form-control" required placeholder="Share your experience..."></textarea>
              <div class="invalid-feedback">Please add a comment for your review.</div>
            </div>
            <button class="btn btn-outline-brand w-100">Submit review</button>
          </form>
        </div>
      <% } else { %>
        <div class="login-prompt">
          <a href="/login">Log in</a> to leave a review.
        </div>
      <% } %>

      <% if (listing.reviews.length > 0) { %>
        <h2 class="show-section-title h5 mt-4">Reviews (<%= listing.reviews.length %>)</h2>
        <div class="row g-3">
          <% for (review of listing.reviews) { %>
            <div class="col-12">
              <div class="card review-card">
                <div class="card-body">
                  <p class="review-author mb-1">
                    <i class="fa-solid fa-circle-user me-1 text-secondary" aria-hidden="true"></i>
                    @<%= review.author ? review.author.username : "[deleted user]" %>
                  </p>
                  <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>
                  <p class="review-comment mb-0"><%= review.comment %></p>
                  <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-2">
                      <button class="btn btn-sm btn-outline-danger">
                        <i class="fa-solid fa-trash me-1" aria-hidden="true"></i>Delete
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
