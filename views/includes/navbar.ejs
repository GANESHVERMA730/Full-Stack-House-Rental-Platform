<style>
  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0.45rem 1.1rem;
    white-space: nowrap;
    font-size: 0.9rem;
  }
  .search-btn:hover { background-color: #e0313a; color: white; }
  .search-btn i { margin-right: 0.4rem; }

  .search-inp {
    border-radius: 25px;
    padding: 0.45rem 1.2rem;
    font-size: 0.9rem;
  }

  /* "Airbnb your home" pill button — always visible */
  .nav-host-btn {
    background: transparent;
    border: 1.5px solid #222;
    border-radius: 25px;
    padding: 0.35rem 1rem;
    color: #222 !important;
    font-weight: 600;
    font-size: 0.88rem;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .nav-host-btn:hover { background: #f5f5f5; }

  /* User pill — bars + avatar */
  .nav-user-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1.5px solid #ccc;
    border-radius: 25px;
    padding: 0.3rem 0.75rem;
    background: white;
    font-size: 0.85rem;
    color: #333;
    white-space: nowrap;
  }
  .nav-user-pill i.fa-circle-user { font-size: 1.25rem; color: #555; }

  /* Logout button */
  .nav-logout-btn {
    background: #222;
    color: white !important;
    border: none;
    border-radius: 25px;
    padding: 0.38rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.15s;
  }
  .nav-logout-btn:hover { background: #444; }

  /* Auth links */
  .nav-auth-link {
    color: #222 !important;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.35rem 0.7rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .nav-auth-link:hover { background: #f0f0f0; }
  .nav-auth-link.signup { background: #fe424d; color: white !important; border-radius: 25px; }
  .nav-auth-link.signup:hover { background: #e0313a; }

  @media (max-width: 767px) {
    .navbar-search-form { width: 100%; margin: 0.4rem 0; }
    .navbar-right-group { width: 100%; flex-wrap: wrap; gap: 0.4rem !important; }
  }
</style>

<nav class="navbar navbar-expand-md border-bottom sticky-top" style="background:white;">
  <div class="container-fluid">

    <!-- Brand logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-brands fa-codepen" style="color:#fe424d;font-size:2rem;"></i>
    </a>

    <!-- Hamburger toggler -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse" data-bs-target="#mainNav"
      aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">

      <!-- Left: Explore -->
      <div class="navbar-nav me-3">
        <a class="nav-link fw-semibold" href="/listings">Explore</a>
      </div>

      <!-- Center: Search bar -->
      <form class="d-flex flex-grow-1 navbar-search-form" role="search"
        action="/listings/search" method="GET">
        <input class="form-control me-2 search-inp" type="search" name="q"
          placeholder="Search destinations" />
        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>Search
        </button>
      </form>

      <!-- Right: Auth actions -->
      <div class="navbar-nav ms-3 d-flex flex-row align-items-center navbar-right-group" style="gap:0.5rem;">

        <!-- "Airbnb your home" — always visible. isLoggedIn middleware handles redirect if not logged in -->
        <a class="nav-host-btn" href="/listings/new">
          <i class="fa-solid fa-plus me-1"></i>Airbnb your home
        </a>

        <% if (locals.currUser) { %>
          <!-- LOGGED IN: show username pill + logout button -->
          <div class="nav-user-pill">
            <i class="fa-solid fa-circle-user"></i>
            <span><%= currUser.username %></span>
          </div>
          <form action="/logout" method="POST" class="m-0 p-0">
            <button type="submit" class="nav-logout-btn">
              <i class="fa-solid fa-right-from-bracket me-1"></i>Log out
            </button>
          </form>

        <% } else { %>
          <!-- LOGGED OUT: show Sign up + Log in -->
          <a class="nav-auth-link" href="/login">Log in</a>
          <a class="nav-auth-link signup" href="/signup">Sign up</a>
        <% } %>

      </div>
    </div>
  </div>
</nav>
